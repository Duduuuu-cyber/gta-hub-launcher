{
  "name": "gtaseoul-launcher",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "author": "GTASeoul",
  "description": "GTASeoul Launcher",
  "build": {
    "appId": "com.gtaseoul.launcher",
    "productName": "GTASeoul",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Duduuuu-cyber",
        "repo": "gta-hub-launcher"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/Logo_Seoul_Prueba_8.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "installerHeader": "build/installerHeader.png",
      "installerSidebar": "build/installerSidebar.png",
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": true
    },
    "files": [
      "dist_build/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bufferutil": "^4.1.0",
    "canvas-confetti": "^1.9.4",
    "discord-rpc": "^4.0.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.12.0",
    "utf-8-validate": "^5.0.10"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "tree-kill": "^1.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.15.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}